generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String       @id @default(cuid())
  name          String?
  email         String?      @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]
  settings      UserSettings?
  submissions   Submission[]
  githubAuth    GithubAuth?
  repoMappings  RepoMapping[]
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model UserSettings {
  id              String  @id @default(cuid())
  userId          String  @unique
  odooUrl         String  @default("")
  odooUsername    String  @default("")
  odooPassword    String  @default("")
  odooDatabase    String  @default("")
  emailRecipients String  @default("")
  emailCc         String  @default("")
  emailBcc        String  @default("")
  emailSignature  String  @default("")
  descriptionStyle  String  @default("")
  weeklyFilterTo    String  @default("")
  displayName       String  @default("")
  wordCountMode     String  @default("concise")
  wordCountShort    Int     @default(20)
  wordCountConcise  Int     @default(70)
  wordCountDetailed Int     @default(110)
  aiProvider        String  @default("openrouter")
  openrouterApiKey  String  @default("")
  openrouterModel   String  @default("")
  geminiApiKey      String  @default("")
  geminiModel       String  @default("")
  emailFrom       String  @default("")
  smtpHost        String  @default("")
  smtpPort        Int     @default(587)
  smtpUser        String  @default("")
  smtpPassword    String  @default("")
  user            User    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model GithubAuth {
  id          String   @id @default(cuid())
  userId      String   @unique
  accessToken String
  username    String
  name        String   @default("")
  emails      String   @default("")
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model RepoMapping {
  id           String   @id @default(cuid())
  userId       String
  repoFullName String
  projectId    Int
  projectName  String
  taskId       Int
  taskName     String
  count        Int      @default(1)
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, repoFullName])
}

model Submission {
  id         String   @id @default(cuid())
  userId     String
  date       String
  entries    String
  emailSent  Boolean  @default(false)
  odooSynced Boolean  @default(false)
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
